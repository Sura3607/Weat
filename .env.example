# ─── Application ───────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── Database (MySQL) ──────────────────────────────────────────────────
# For local Docker Compose:
DATABASE_URL=mysql://weat:weatpassword@localhost:3306/weat

# For production (AWS RDS, PlanetScale, etc.):
# DATABASE_URL=mysql://user:password@host:3306/database

# Docker Compose MySQL settings
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=weat
MYSQL_USER=weat
MYSQL_PASSWORD=weatpassword

# ─── Authentication ────────────────────────────────────────────────────
# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─── Google OAuth ──────────────────────────────────────────────────────
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
#
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback
# 3. For production, add: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Manus OAuth (if using Manus platform) ─────────────────────────────
# VITE_APP_ID=your-manus-app-id
# OAUTH_SERVER_URL=https://auth.manus.dev
# OWNER_OPEN_ID=your-owner-open-id

# ─── AWS S3 (for image uploads) ────────────────────────────────────────
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=ap-southeast-1
# S3_BUCKET_NAME=your-bucket-name

# ─── AI Services ───────────────────────────────────────────────────────
# BUILT_IN_FORGE_API_URL=https://api.openai.com/v1
# BUILT_IN_FORGE_API_KEY=your-api-key
