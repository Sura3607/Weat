# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/weat

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Exa.ai (restaurant suggestions)
EXA_API_KEY=your-exa-api-key

# CORS
CORS_ORIGIN=http://localhost:3000

# Upload
MAX_FILE_SIZE_MB=8
UPLOAD_DIR=./uploads
