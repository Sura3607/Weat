# ── Weat Production Environment ──────────────────────────
# Copy this file to .env and fill in values before deploying

# ── Database ─────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=weat

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_64_CHARS
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────
# Use your EC2 public IP or domain. Use * for demo.
CORS_ORIGIN=*

# ── Frontend URLs (baked into Next.js at build time) ─────
# Replace YOUR_EC2_IP with actual EC2 public IP or domain
NEXT_PUBLIC_API_URL=http://YOUR_EC2_IP/api/v1
NEXT_PUBLIC_WS_URL=http://YOUR_EC2_IP

# ── Optional: AI Services ────────────────────────────────
OPENAI_API_KEY=
EXA_API_KEY=

# ── Upload ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=8
